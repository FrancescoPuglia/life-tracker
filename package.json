    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.0.1",
    "baseline-browser-mapping": "^2.9.11",
    "eslint": "^8",
    "eslint-config-next": "15",
    "jsdom": "^26.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "vitest": "^3.2.4"
  }
