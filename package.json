{
  "name": "life-tracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && node -e \"require('fs').closeSync(require('fs').openSync('out/.nojekyll','a'))\"",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "firebase:deploy": "npm run build && firebase deploy",
    "firebase:rules": "firebase deploy --only firestore:rules"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
