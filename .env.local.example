# ============================================================================
# LIFE TRACKER - Environment Variables Template
# ============================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to `.env.local`
# 2. Fill in your actual values
# 3. NEVER commit `.env.local` to Git
#
# ============================================================================

# Firebase Configuration (Client-Side - Safe to Expose)
# Get these from: Firebase Console -> Project Settings -> General -> Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-ABCD1234

# Enable Firebase (set to 'false' to use IndexedDB only)
NEXT_PUBLIC_USE_FIREBASE=true

# ============================================================================
# AI Provider Configuration
# ============================================================================
# Choose your AI backend: 'ollama' (default, free, local) or 'openai'
AI_PROVIDER=ollama

# --- Ollama (default) ---
# Install: https://ollama.com
# Start:   ollama serve
# Pull:    ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_CHAT_MODEL=llama3.2
# OLLAMA_EMBED_MODEL=nomic-embed-text  # Optional, for future semantic search

# --- OpenAI (optional) ---
# Get key from: https://platform.openai.com/api-keys
# Used for BOTH AI chat and premium TTS voice
# OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE
# OPENAI_CHAT_MODEL=gpt-3.5-turbo
# OPENAI_EMBED_MODEL=text-embedding-3-small

# ============================================================================
# Voice TTS Providers (optional)
# ============================================================================
# Premium TTS providers for the Voice System. API keys stay server-side.
# If not set, the browser's built-in SpeechSynthesis is used (free, offline).

# --- ElevenLabs (optional) ---
# Ultra-realistic multilingual voices
# Get key from: https://elevenlabs.io/app/settings/api-keys
# ELEVENLABS_API_KEY=your_elevenlabs_key_here
